rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user owns the existing document
    function isOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Check if the incoming document has the correct userId
    function isCreatingOwned() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Prevent userId from being changed on update
    function ownerUnchanged() {
      return request.resource.data.userId == request.auth.uid;
    }

    // Transactions
    match /transactions/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned();
      allow update: if isOwner() && ownerUnchanged();
      allow delete: if isOwner();
    }

    // Opening Balances
    match /opening_balances/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned();
      allow update: if isOwner() && ownerUnchanged();
      allow delete: if isOwner();
    }

    // KHOC Transactions
    match /khoc_transactions/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned();
      allow update: if isOwner() && ownerUnchanged();
      allow delete: if isOwner();
    }

    // KHOC Opening Balances
    match /khoc_opening_balances/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned();
      allow update: if isOwner() && ownerUnchanged();
      allow delete: if isOwner();
    }

    // Monthly Images
    match /monthly_images/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned();
      allow delete: if isOwner();
    }

    // KHOC Monthly Images
    match /khoc_monthly_images/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned();
      allow delete: if isOwner();
    }

    // Notes
    match /notes/{docId} {
      allow read: if isOwner();
      allow create: if isCreatingOwned() &&
                       request.resource.data.title is string &&
                       request.resource.data.content is string &&
                       request.resource.data.title.size() > 0 &&
                       request.resource.data.title.size() <= 100 &&
                       request.resource.data.content.size() > 0 &&
                       request.resource.data.content.size() <= 5000;
      allow update: if isOwner() && ownerUnchanged();
      allow delete: if isOwner();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
